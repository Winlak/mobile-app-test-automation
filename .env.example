# Значения окружения имеют приоритет над config/devices.yaml.
APPIUM_URL=http://127.0.0.1:4723
DEVICE_NAME=Android Emulator
ANDROID_VERSION=35
# Для физического устройства укажите serial из `adb devices`.
# UDID=emulator-5554
# APK_PATH=/absolute/path/to/app-debug.apk
EXPLICIT_TIMEOUT=12
NEW_COMMAND_TIMEOUT=120
ADB_EXEC_TIMEOUT=120000
SERVER_INSTALL_TIMEOUT=120000
SERVER_LAUNCH_TIMEOUT=120000
# Только для отладки локального падения. По умолчанию данные очищаются перед каждым тестом.
# KEEP_APP_DATA=false
